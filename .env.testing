APP_NAME="Document Tracker Test"
APP_ENV=testing
APP_KEY=base64:d3gFlGiI/2eZgUkytjGjwrJJ4z2FDOTM83ZLrdMKuQ4=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=document_tracker_test
DB_USERNAME=root
DB_PASSWORD=041601
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_0900_ai_ci
DB_ENGINE=InnoDB

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Security
SEC_AUTH_MAX_ATTEMPTS=5
SEC_AUTH_LOCKOUT_MINUTES=15
SEC_AUTH_REMEMBER_ME_DAYS=7
SEC_AUTH_REQUIRE_EMAIL_VERIFICATION=true
SEC_AUTH_ENFORCE_MFA=false
SEC_AUTH_PASSWORD_RESET_EXPIRE=15
SEC_AUTH_PASSWORD_RESET_THROTTLE=60
SEC_PASSWORD_MIN_LENGTH=12
SEC_PASSWORD_REQUIRE_UPPERCASE=true
SEC_PASSWORD_REQUIRE_LOWERCASE=true
SEC_PASSWORD_REQUIRE_NUMBER=true
SEC_PASSWORD_REQUIRE_SYMBOL=true
SEC_PASSWORD_MAX_AGE_DAYS=90
SEC_PASSWORD_HISTORY_COUNT=5
SEC_PASSWORD_EXPIRY_WARNING_DAYS=14

SEC_HEADER_X_FRAME_OPTIONS=DENY
SEC_HEADER_X_CONTENT_TYPE_OPTIONS=nosniff
SEC_HEADER_X_XSS_PROTECTION="1; mode=block"
SEC_HEADER_REFERRER_POLICY=strict-origin-when-cross-origin
SEC_HEADER_PERMISSIONS_POLICY="geolocation=(), microphone=(), camera=(self), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=()"
SEC_HSTS_ENABLED=true
SEC_HSTS_MAX_AGE=31536000
SEC_HSTS_INCLUDE_SUB_DOMAINS=true
SEC_HSTS_PRELOAD=false

SEC_SANITIZE_ALL_INPUTS=true
SEC_STRIP_SCRIPT_TAGS=true
SEC_ENCODE_SPECIAL_CHARS=true
SEC_MAX_INPUT_LENGTH=10000

SEC_RATE_LIMIT_WEB_MAX=60
SEC_RATE_LIMIT_WEB_DECAY=1
SEC_RATE_LIMIT_API_MAX=120
SEC_RATE_LIMIT_API_DECAY=1
SEC_RATE_LIMIT_LOGIN_MAX=5
SEC_RATE_LIMIT_LOGIN_DECAY=1
SEC_RATE_LIMIT_PASSWORD_RESET_MAX=3
SEC_RATE_LIMIT_PASSWORD_RESET_DECAY=15

SEC_AUDIT_ENABLED=true
SEC_AUDIT_LOG_REQUESTS=false
SEC_AUDIT_LOG_AUTH=true
SEC_AUDIT_LOG_MODEL_CHANGES=true
SEC_AUDIT_LOG_FAILED_LOGINS=true
SEC_AUDIT_LOG_DATA_EXPORTS=true
SEC_AUDIT_RETENTION_DAYS=365
SEC_AUDIT_CHANNEL=security

SEC_ENCRYPTION_CIPHER=AES-256-CBC
SEC_ENCRYPT_PII=true
SEC_ENCRYPT_DB_COLUMNS=true
SEC_ENCRYPTION_KEY_ROTATION_DAYS=90

SEC_UPLOAD_MAX_SIZE=10485760
SEC_UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,csv
SEC_UPLOAD_SCAN_MALWARE=true
SEC_UPLOAD_STORE_OUTSIDE_WEBROOT=true

SEC_CORS_ALLOWED_ORIGINS=http://localhost
SEC_CORS_ALLOW_CREDENTIALS=true
SEC_CORS_MAX_AGE=86400

SEC_DPO_EMAIL=dpo@localhost
SEC_BREACH_NOTIFICATION=true
SEC_BREACH_NOTIFICATION_EMAIL=security@localhost
SEC_DATA_RETENTION_DAYS=1825
SEC_PRIVACY_NOTICE_URL=/privacy
SEC_CONSENT_REQUIRED=true

SEC_BLOCKED_IPS=
SEC_WHITELIST_IPS=
SEC_ENFORCE_HTTPS=false
SEC_TRUST_PROXIES=*

SEC_DETECT_BRUTE_FORCE=true
SEC_DETECT_SESSION_HIJACKING=true
SEC_ALERT_SUSPICIOUS=true
SEC_ALERT_EMAIL=security@localhost
SEC_INCIDENT_RESPONSE_TEAM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback